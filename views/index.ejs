<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blog Home</title>
</head>
<body>
    <%- include("partials/header") %>  <!-- Include Header -->
    <div class="text-left">
        <h1>Blog Posts</h1>

        <% if (posts.length === 0) { %>
            <p>No posts available. Be the first to create one!</p>
        <% } else { %>
            <ul class="posts-list">
                <% posts.forEach(post => { %>
                    <li class="post-block">
                        <div class="post-title">
                            <h2><%= post.title %></h2>
                        </div>
                        
                        <div class="post-content">
                            <p><%= post.content.length > 100 ? post.content.substring(0, 100) + "..." : post.content %></p>
                        </div>
                        
                        <% if (post.content.length > 100) { %>  
                            <div class="read-more-container">
                                <a href="/post/<%= post.id %>" class="read-more">Read More</a>
                            </div>
                        <% } %>
                        
                        <div class="post-actions">
                            <a class="btn-edit button-container" href="/edit/<%= post.id %>">Edit</a>
                            <form action="/delete/<%= post.id %>" method="POST" onsubmit="return confirmDelete()">
                                <button type="submit" class="btn-delete button-container">Delete</button>
                            </form>
                        </div>
                    </li>
                <% }); %>
            </ul>
        <% } %>
    </div>
    
    <script src="/script.js"></script>
</body>
</html>
